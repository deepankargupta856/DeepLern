import numpy as np

x=np.array([[0,0],[0,1],[1,0],[1,1]])
y=np.array([[0],[1],[1],[0]])
w1=np.random.randn(2,2)
w2=np.random.randn(2,1)
b1=np.random.randn(1,2)
b2=np.random.randn(1,1)
lr=0.1
def sigmoid(x):
    return 1/(1+np.exp(-x))
def sigmoid_der(x):
    return x*(1-x)
    
for epoch in range(100000):
    hidden_lay=sigmoid(np.dot(x,w1)+b1)
    output_lay=sigmoid(np.dot(hidden_lay,w2)+b2)
    error=y-output_lay
    d_output=error*sigmoid_der(output_lay)
    d_hidden=d_output.dot(w2.T)*sigmoid_der(hidden_lay)
    w2=w2+hidden_lay.T.dot(d_output)*lr
    w1=w1+x.T.dot(d_hidden)*lr
    b2=b2+np.sum(d_output,axis=0)*lr
    b1=b1+np.sum(d_hidden,axis=0)*lr
print(output_lay)

