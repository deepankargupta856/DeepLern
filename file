import numpy as np
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import SimpleRNN, Dense
from tensorflow.keras.utils import to_categorical

text = "HELLO"

chars = sorted(list(set(text)))
char_to_index = {c: i for i, c in enumerate(chars)}
index_to_char = {i: c for i, c in enumerate(chars)}

print("Character mapping")
print(char_to_index)

X = []
y = []

for i in range(len(text) - 1):
    X.append(char_to_index[text[i]])
    y.append(char_to_index[text[i + 1]])

X = np.array(X)
y = np.array(y)

num_classes = len(chars)

X = to_categorical(X, num_classes)
y = to_categorical(y, num_classes)

X = X.reshape((X.shape[0], 1, X.shape[1]))

print("Input shape:", X.shape)

model = Sequential()

model.add(SimpleRNN(units=8, input_shape=(1, num_classes), activation='tanh'))

model.add(Dense(num_classes, activation='softmax'))

model.compile(
    loss='categorical_crossentropy',
    optimizer='adam',
    metrics=['accuracy']
)

model.fit(X, y, epochs=200, verbose=1)

def predict_next_char(char):
    x = char_to_index[char]
    x = to_categorical(x, num_classes)
    x = x.reshape((1, 1, num_classes))

    prediction = model.predict(x, verbose=0)

    index = np.argmax(prediction)

    return index_to_char[index]

print("\nGenerated text")

char = "H"

generated_text = char

for i in range(4):
    next_char = predict_next_char(char)

    generated_text += next_char

    char = next_char

print(generated_text)

