import tensorflow as tf
from tensorflow import keras
from tensorflow.keras import layers
import numpy as np
import matplotlib.pyplot as  plt


(x_train,y_train),(x_test,y_test)=keras.datasets.mnist.load_data()



x_train=x_train.reshape(-1,28,28,1)
x_test=x_test.reshape(-1,28,28,1)

histories=[]
model_names=[]
def train_model(model,name,epoch):
    model.compile(optimizer='adam',
                  loss='sparse_categorical_crossentropy',
                  metrics=['accuracy'])
    history=model.fit(x_train,y_train,epochs=epoch,validation_data=(x_test,y_test))
    histories.append(history)
    model_names.append(name)

model1=keras.Sequential([
    layers.Input(shape=(28,28,1)),
    layers.Conv2D(32,(3,3),activation='relu'),
    layers.MaxPooling2D((2,2)),
    layers.Conv2D(64,(3,3),activation='relu'),
    layers.MaxPooling2D((2,2)),
    layers.Flatten(),
    layers.Dense(64,activation='relu'),
    layers.Dense(10,activation='softmax')
                        ])
                        
train_model(model1,"norm_conv",3)
                        
                        
                        

model2=keras.Sequential([
    layers.Input(shape=(28,28,1)),
    layers.SeparableConv2D(32,(3,3),activation='relu'),
    layers.MaxPooling2D((2,2)),
    layers.SeparableConv2D(64,(3,3),activation='relu'),
    layers.MaxPooling2D((2,2)),
    layers.Flatten(),
    layers.Dense(64,activation='relu'),
    layers.Dense(10,activation='softmax')
                        ])
                        
train_model(model2,"seperableconv",3)
                        
                        
                        

model3=keras.Sequential([
    layers.Input(shape=(28,28,1)),
    layers.Conv2D(32,(5,5),activation='relu'),
    layers.MaxPooling2D((2,2)),
    layers.Conv2D(64,(5,5),activation='relu'),
    layers.MaxPooling2D((2,2)),
    layers.Flatten(),
    layers.Dense(64,activation='relu'),
    layers.Dense(10,activation='softmax')
                        ])
                        
train_model(model3,"5*5 kernel",3)
                        
                        
                        

model4=keras.Sequential([
    layers.Input(shape=(28,28,1)),
    layers.Conv2D(32,(5,5),activation='relu',dilation_rate=2),
    layers.MaxPooling2D((2,2)),
    layers.Conv2D(64,(5,5),activation='relu'),
    layers.MaxPooling2D((2,2)),
    layers.Flatten(),
    layers.Dense(64,activation='relu'),
    layers.Dense(10,activation='softmax')
                        ])
train_model(model4," dilation",3)
                        
                        
                        

model5=keras.Sequential([
    layers.Input(shape=(28,28,1)),
    layers.Conv2D(32,(5,5),activation='relu',strides=2),
    layers.MaxPooling2D((2,2)),
    layers.Conv2D(64,(5,5),activation='relu'),
    layers.MaxPooling2D((2,2)),
    layers.Flatten(),
    layers.Dense(64,activation='relu'),
    layers.Dense(10,activation='softmax')
                        ])
                        
train_model(model5," strides",3)
                        
                        
                        

model6=keras.Sequential([
    layers.Input(shape=(28,28,1)),
    layers.Conv2D(32,(5,5),activation='relu',strides=2),
    layers.AveragePooling2D((2,2)),
    layers.Conv2D(64,(5,5),activation='relu'),
    layers.AveragePooling2D((2,2)),
    layers.Flatten(),
    layers.Dense(64,activation='relu'),
    layers.Dense(10,activation='softmax')
                        ])
                        
train_model(model6," average pooling",3)
                        
                        
                        

plt.figure(figsize=(10,6))
for i,history in enumerate(histories):
    plt.plot(history.history['val_accuracy'],label=model_names[i])
    plt.title("cnn variation")
    plt.xlabel("epochs")
    plt.ylabel("accuracy")
    plt.legend()
    plt.grid()
plt.show()

