import numpy as np
import pandas as pd
import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense,LSTM,GRU
from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_squared_error
import urllib.request
import matplotlib.pyplot as plt

url='https://raw.githubusercontent.com/jbrownlee/Datasets/master/airline-passengers.csv'
urllib.request.urlretrieve(url,"airline.csv")

df=pd.read_csv("airline.csv")
df.head()
               

data=df["Passengers"].values.astype(float)
scaler=MinMaxScaler()
data_scaled=scaler.fit_transform(data.reshape(-1,1))

def create_sequence(data,seq_length=10):
    X,Y=[],[]
    for  i in range(len(data)-seq_length):
        X.append(data[i:i+seq_length])
        Y.append(data[i+seq_length])
    return np.array(X),np.array(Y)
    
X,Y=create_sequence(data_scaled,seq_length=10)

split=int(len(X)*0.8)
X_train,X_test=X[:split],X[split:]
Y_train,Y_test=Y[:split],Y[split:]
X_train=X_train.reshape((X_train.shape[0],X_train.shape[1],1))
X_test=X_test.reshape((X_test.shape[0],X_test.shape[1],1))

lstm_model=Sequential([
    LSTM(32,input_shape=(10,1)),
    Dense(1)
])
lstm_model.compile(
    optimizer='adam',
    loss='mse'
)
lstm_history=lstm_model.fit(X_train,Y_train,epochs=50,batch_size=8)
print("lstm_model training done ")

gru_model=Sequential([
    GRU(32,input_shape=(10,1)),
    Dense(1)
])
gru_model.compile(
    optimizer='adam',
    loss='mse'
)
gru_history=gru_model.fit(X_train,Y_train,epochs=50,batch_size=8,verbose=0)
print("gru_model training done ")

lstm_pred=lstm_model.predict(X_test)
gru_pred=gru_model.predict(X_test)

lstm_actual=scaler.inverse_transform(lstm_pred)
gru_actual=scaler.inverse_transform(gru_pred)
real_actual=scaler.inverse_transform(Y_test.reshape(-1,1))

print("Trainning_loss_plot")
plt.figure(figsize=(10,4))
plt.plot(lstm_history.history['loss'],
         label='lstm_loss',
         color='steelblue')
plt.plot(gru_history.history['loss'],
         label='gru_loss',
         color='seagreen')
plt.title("Training loss for gru and lstm")
plt.xlabel('epochs')
plt.ylabel('mse loss')
plt.legend()
plt.show()

print("prediction plot")
plt.figure(figsize=(10,4))
plt.plot(
    real_actual,
    label='actual',
    color='gray'
    
)
plt.plot(
    lstm_actual,
    label='Lstm',
    color='steelblue'
    
)
plt.plot(
    gru_actual,
    label='Gru',
    color='seagreen'
    
)
plt.title("lstm vs gru vs actual")
plt.xlabel("month")
plt.ylabel("passenger")
plt.legend()
plt.show()

print("\n Month|actual|lstm_pred|gru_pred")
print("-"*45)
for i in range(len(real_actual)):
    print(
        f"{i+1:>5}|"
        f"{real_actual[i][0]:>6.0f}|"
        f"{lstm_actual[i][0]:>9.0f}|"
        f"{gru_actual[i][0]:>8.0f}|"


    )

lstm_mse=mean_squared_error(real_actual,lstm_actual)
gru_mse=mean_squared_error(real_actual,gru_actual)

print("\n model|mse|parameters")
print(
    f"{'lstm':>6}"
    f"{lstm_mse:>10.0f}"
    f"{lstm_model.count_params():>15.0f}"
)
print(
    f"{'gru':>6}"
    f"{gru_mse:>10.0f}"
    f"{gru_model.count_params():>15.0f}"
)
